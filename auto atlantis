-- ตรวจสอบการรันซ้ำ
if _G.AtlantisRunning then
    warn("Atlantis Ring Script is already running!")
    return
end
_G.AtlantisRunning = true

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer

local function getCharacter()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart", 10)
    return char, root
end

-- ฟังก์ชันวาร์ปแบบล็อค (ปรับปรุงให้รองรับการสั่งวาร์ปใหม่แทรกได้ทันที)
local function teleportAndLock(targetCFrame, duration)
    local _, currentRoot = getCharacter()
    if not currentRoot then return end
    
    local connection
    local startTime = tick()
    
    connection = RunService.Heartbeat:Connect(function()
        if currentRoot and currentRoot.Parent and (tick() - startTime) < duration then
            currentRoot.CFrame = targetCFrame
            currentRoot.Velocity = Vector3.new(0, 0, 0)
        else
            connection:Disconnect()
        end
    end)
    
    task.wait(duration)
end

task.spawn(function()
    local success, err = pcall(function()
        local things = workspace:WaitForChild("__THINGS")
        
        -- 1. Atlantis Enter
        local _, root = getCharacter()
        local enterPoint = things:WaitForChild("Instances"):WaitForChild("Atlantis"):WaitForChild("Teleports"):WaitForChild("Enter")
        root.CFrame = enterPoint:GetPivot()
        
        task.wait(2)
        
        -- 2. Atlantis Chest: 2
        local activeFolder = things:WaitForChild("__INSTANCE_CONTAINER"):WaitForChild("Active")
        local atlantisFolder = activeFolder:WaitForChild("Atlantis", 15)
        local chest = atlantisFolder:WaitForChild("INTERACT"):WaitForChild("Chests"):WaitForChild("InstanceChest: 2", 10)
        
        if chest then
            teleportAndLock(chest:GetPivot() * CFrame.new(0, 2, 0), 0.5) 
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end

        task.wait(1)

        -- 3. ระบบตรวจจับ Rings (แก้ Logic การ Queue)
        print("Continuous Ring Monitoring Started...")
        local ringsFolder = atlantisFolder:WaitForChild("Rings", 10)
        
        if ringsFolder then
            -- ฟังก์ชันหลักในการวาร์ปไปหา Ring
            local function processRing(ringModel)
                if ringModel and ringModel:IsA("Model") and _G.AtlantisRunning then
                    task.spawn(function() -- แยก Thread เพื่อให้วาร์ปอันต่อไปได้ทันที
                        local targetCF = ringModel:GetPivot()
                        teleportAndLock(targetCF, 1)
                    end)
                end
            end

            -- ตรวจสอบอันที่ค้างอยู่เดิม
            for _, item in pairs(ringsFolder:GetChildren()) do
                processRing(item)
                task.wait(0.1) -- เว้นจังหวะนิดนึงสำหรับอันที่กองอยู่ก่อนหน้า
            end

            -- ดักจับการเกิดใหม่ (สำคัญ: ใช้ task.spawn ด้านในเพื่อไม่ให้ขัดจังหวะ Listener)
            local ringConnection
            ringConnection = ringsFolder.ChildAdded:Connect(function(child)
                if _G.AtlantisRunning then
                    task.wait(0.05) -- รอ Object เซ็ตตัว
                    processRing(child)
                else
                    ringConnection:Disconnect()
                end
            end)

            -- เลิกใช้ Loop เช็ค Parent เพื่อป้องกัน Script ปิดตัวเร็วเกินไป
            while _G.AtlantisRunning do
                task.wait(1)
                -- ถ้าหลุดจากแมพ Atlantis ให้หยุดการทำงาน
                if not atlantisFolder.Parent then break end
            end
            
            if ringConnection then ringConnection:Disconnect() end
        end
    end)

    if not success then
        warn("Atlantis Model Error: " .. tostring(err))
    end

    _G.AtlantisRunning = false
    print("Atlantis Monitoring Stopped.")
end)
