local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- [[ ANTI-SPAM SYSTEM ]]
if _G.IsTeleporting then 
    warn("Script is already running!")
    return 
end
_G.IsTeleporting = true

-- [[ LOCATIONS DATA ]]
local locations = {
    {mapName = "3 | Castle", machineName = "DailyDiamonds1"},
    {mapName = "17 | Jungle", machineName = "DailyPotions1"},
    {mapName = "21 | Coral Reef", machineName = "DailyEnchants1"},
    {mapName = "24 | Palm Beach", machineName = "DailyItems1"},
    {mapName = "32 | Red Desert", machineName = "DailyDiamonds2"},
    {mapName = "78 | Dungeon Entrance", machineName = "DailyDiamonds3"},
    {mapName = "83 | Cotton Candy Forest", machineName = "DailyPotions2"},
    {mapName = "88 | Carnival", machineName = "DailyEnchants2"},
    {mapName = "90 | Clouds", machineName = "DailyItems2"}
}

-- [[ EXECUTION ]]
for _, info in ipairs(locations) do
    local mapFolder = workspace.Map:FindFirstChild(info.mapName)
    
    if mapFolder then
        -- 1. วาร์ปไปที่ PERSISTENT ทันที (Instant Warp)
        local persistent = mapFolder:FindFirstChild("PERSISTENT")
        if persistent then
            local pCFrame, _ = persistent:GetBoundingBox()
            
            -- ใช้ RunService รอจังหวะเฟรมที่เหมาะสมก่อนวาร์ป
            RunService.Heartbeat:Wait()
            humanoidRootPart.CFrame = pCFrame + Vector3.new(0, 5, 0)
            
            -- รอให้พื้นที่โหลด (1 วินาทีตามกำหนดเดิม)
            task.wait(1) 
        end

        -- 2. เช็คเงื่อนไขใน INTERACT
        local interact = mapFolder:FindFirstChild("INTERACT")
        if interact then
            local machinesFolder = interact:FindFirstChild("Machines")
            local machine = machinesFolder and machinesFolder:FindFirstChild(info.machineName)
            
            if machine then
                local billboard = machine:FindFirstChild("Billboard")
                local gui = billboard and billboard:FindFirstChild("BillboardGui")
                local timer = gui and gui:FindFirstChild("Timer")

                if timer and timer.Text == "Claim!" then
                    -- 3. วาร์ปไปที่ Pad ทันที (Instant Warp)
                    local pad = machine:FindFirstChild("Pad")
                    if pad and pad:IsA("BasePart") then
                        RunService.Heartbeat:Wait()
                        humanoidRootPart.CFrame = pad.CFrame + Vector3.new(0, 3, 0)
                        print("Claimed at: " .. info.mapName)
                        task.wait(0.5) 
                    end
                else
                    print("Not ready: " .. info.mapName)
                end
            end
        end
    end
    -- ใช้ RunService คุมจังหวะการเปลี่ยนแมพ
    RunService.Heartbeat:Wait()
end

-- ปลดล็อคระบบกันกดรัว
_G.IsTeleporting = false
print("Teleport Process Finished.")
